{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FVP via fvp-gdb (attach)",
            "type": "gdbtarget",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "program": "${command:cmsis-csolution.getBinaryFile}",
            "gdb": "arm-none-eabi-gdb",
            "auxiliaryGdb": false,
            "//": "Run the 'FVP: Start' task once, then F5 / Shift+F5 cycle freely. 'load' pushes the current ELF into the running FVP each F5, so no restart needed after rebuilding. Use 'FVP: Stop' / 'FVP: Restart' only when the FVP itself misbehaves.",
            "initCommands": [
                "set arch arm",
                "set tdesc filename /dev/null",
                "monitor reset halt",
                "load",
                "monitor reset halt",
                "tbreak main"
            ],
            "target": {
                "port": "3333"
            }
        },
        {
            "name": "CMSIS_DAP@pyOCD (attach)",
            "type": "gdbtarget",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "program": "${command:cmsis-csolution.getBinaryFile}",
            "gdb": "arm-none-eabi-gdb",
            "auxiliaryGdb": false,
            "initCommands": [
                "set arch arm",
                "set tdesc filename /dev/null",
                "monitor reset halt",
                "load",
                "monitor reset halt",
                "tbreak main"
            ],
            "target": {
                "port": "3333"
            }
        },
        {
            "name": "M55_HE CMSIS_DAP@pyOCD (launch)",
            "type": "gdbtarget",
            "request": "launch",
            "cwd": "${workspaceFolder}/",
            "program": "out/all_ops/AE722F80F55D5LS/Debug/all_ops.axf",
            "gdb": "arm-none-eabi-gdb",
            "auxiliaryGdb": true,
            "preLaunchTask": "CMSIS Load",
            "initCommands": [
                "monitor reset halt",
                "tbreak main"
            ],
            "customResetCommands": [
                "monitor reset halt",
                "maintenance flush register-cache",
                "maintenance flush dcache",
                "tbreak main",
                "continue"
            ],
            "target": {
                "server": "pyocd",
                "serverParameters": [
                    "gdbserver",
                    "--probe",
                    "cmsisdap:",
                    "--persist",
                    "--cbuild-run",
                    "${command:cmsis-csolution.getCbuildRunFile}",
                    "--quiet",
                    "--log",
                    "*.cbuild_run,*server=info"
                ],
                "port": "3333"
            },
            "cmsis": {
                "cbuildRunFile": "${command:cmsis-csolution.getCbuildRunFile}",
                "updateConfiguration": "auto"
            }
        },
        {
            "name": "M55_HE CMSIS_DAP@pyOCD (attach)",
            "type": "gdbtarget",
            "request": "attach",
            "cwd": "${workspaceFolder}/",
            "program": "out/all_ops/AE722F80F55D5LS/Debug/all_ops.axf",
            "gdb": "arm-none-eabi-gdb",
            "auxiliaryGdb": true,
            "initCommands": [
                ""
            ],
            "customResetCommands": [
                "monitor reset halt",
                "maintenance flush register-cache",
                "maintenance flush dcache",
                "tbreak main",
                "continue"
            ],
            "target": {
                "port": "3333"
            },
            "cmsis": {
                "cbuildRunFile": "${command:cmsis-csolution.getCbuildRunFile}",
                "updateConfiguration": "auto"
            }
        },
        {
            "name": "M55_HP CMSIS_DAP@pyOCD (attach)",
            "type": "gdbtarget",
            "request": "attach",
            "cwd": "${workspaceFolder}/",
            "program": "",
            "gdb": "arm-none-eabi-gdb",
            "auxiliaryGdb": true,
            "initCommands": [
                ""
            ],
            "customResetCommands": [
                "monitor reset halt",
                "maintenance flush register-cache",
                "maintenance flush dcache",
                "tbreak main",
                "continue"
            ],
            "target": {
                "port": "3334"
            },
            "cmsis": {
                "cbuildRunFile": "${command:cmsis-csolution.getCbuildRunFile}",
                "updateConfiguration": "auto"
            }
        }
    ]
}
